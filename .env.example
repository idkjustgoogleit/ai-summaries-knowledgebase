# =============================================================================
# AI Summaries Library - Environment Configuration
# =============================================================================
# This file is used by both WEB and WORKER containers.
# Each container uses only the variables relevant to its mode.
#
# Modes:
#   - WEB (summary-library container): Main web application
#   - WORKER (summaries-worker container): Background video processor
# =============================================================================
#
#APP_MODE=WEB #<<<< CHANGE THESE!
#APP_MODE=WORKER #<<<< CHANGE THESE!
#
# -----------------------------------------------------------------------------
# Database Configuration (Required by BOTH containers)
# -----------------------------------------------------------------------------
DB_USER=admin
DB_PASSWORD=CHANGE_THIS_PASSWORD
DB_HOST=postgres
DB_PORT=5432
DB_NAME=summaries
DATABASE_URL=postgresql://admin:CHANGE_THIS_PASSWORD@postgres:5432/summaries
DOWNLOAD_DIR=/downloads #map docker volume
# -----------------------------------------------------------------------------
# WEB Container Only - Admin & Authentication (Required for OIDC)
# -----------------------------------------------------------------------------
# Maps OIDC username to admin role (can also use OIDC groups)
ADMIN_USERNAME=admin

# OIDC Configuration (REQUIRED - OIDC-Only Authentication)
OIDC_ISSUER=https://authelia.yourdomain.com
OIDC_CLIENT_ID=summaries
OIDC_CLIENT_SECRET=your-client-secret-from-authelia
OIDC_REDIRECT_URI=https://summaries.yourdomain.com/api/auth/oidc/callback
OIDC_LOGOUT_REDIRECT_URI=https://summaries.yourdomain.com

# OIDC Security Enhancements (Required in production)
OIDC_PKCE_ENABLED=true
OIDC_STATE_ENABLED=true
OIDC_NONCE_ENABLED=true

# Session Configurations (Required for WEB container)
SESSION_SECRET=CHANGE_THIS_TO_RANDOM_STRING_MIN_32_CHARS
FETCH_HEADERS_TIMEOUT=1800000
FETCH_BODY_TIMEOUT=7200000

# -----------------------------------------------------------------------------
# Optional Configuration (Both containers)
# -----------------------------------------------------------------------------
# Frontend URL (for CORS - required in production)
FRONTEND_URL=https://summaries.yourdomain.com

# Debug Configuration
DEBUG_MODE=false
NODE_ENV=production
LOG_LEVEL=info
